{
  "name": "go-ripgrep",
  "version": "0.0.1",
  "description": "Pure Go ripgrep implementation with AVX2 SIMD acceleration and no CGO dependencies",
  "bin": {
    "rg": "bin/rg"
  },
  "scripts": {
    "postinstall": "node scripts/postinstall.js"
  },
  "files": [
    "bin/",
    "scripts/",
    "README.md"
  ],
  "keywords": [
    "ripgrep",
    "grep",
    "search",
    "pure-go",
    "simd",
    "avx2",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/startvibecoding/go-ripgrep.git",
    "directory": "npm"
  },
  "engines": {
    "node": ">=14"
  },
  "optionalDependencies": {
    "go-ripgrep-linux-x64": "0.0.1",
    "go-ripgrep-linux-arm64": "0.0.1",
    "go-ripgrep-linux-loong64": "0.0.1",
    "go-ripgrep-linux-musl-x64": "0.0.1",
    "go-ripgrep-darwin-x64": "0.0.1",
    "go-ripgrep-darwin-arm64": "0.0.1",
    "go-ripgrep-win32-x64": "0.0.1",
    "go-ripgrep-win32-arm64": "0.0.1",
    "go-ripgrep-freebsd-x64": "0.0.1",
    "go-ripgrep-freebsd-arm64": "0.0.1"
  }
}
